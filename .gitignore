# ── Node ────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Build output ─────────────────────────────────────────────────
dist/
dist-ssr/
build/

# ── Environment files ────────────────────────────────────────────
# Never commit secrets — copy .env.example and fill in locally
.env
.env.*
!.env.example
frontend/.env*
!frontend/.env.example
backend/.env*
!backend/.env.example

# ── Uploaded files (keep the folder, not its contents) ──────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── OS junk ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Temp / cache ─────────────────────────────────────────────────
*.tmp
*.temp
*.cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ── Vite / TypeScript ────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Coverage / test output ───────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Misc ─────────────────────────────────────────────────────────
*.local
*.log
